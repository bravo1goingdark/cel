{
  "name": "cel-player",
  "version": "0.1.1",
  "description": "Tiny runtime that plays Cel scene files (~1KB)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cel-core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  },
  "license": "MIT"
}
