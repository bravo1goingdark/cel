{
  "name": "@ascii-anim/player",
  "version": "0.1.0-alpha.0",
  "description": "Tiny runtime that plays ASCII Anim scene files (~1KB)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ascii-anim/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  },
  "license": "MIT"
}
