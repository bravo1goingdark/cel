{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascii-anim.app/schema/v1.json",
  "title": "ASCII Anim Scene",
  "description": "A complete ASCII character-grid animation scene (v1).",
  "type": "object",
  "required": ["version", "duration", "sprites"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema URL for editor autocomplete."
    },
    "version": {
      "const": 1,
      "description": "Schema version. Currently 1."
    },
    "duration": {
      "type": "integer",
      "minimum": 1,
      "description": "Animation duration in milliseconds."
    },
    "fps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 120,
      "default": 60,
      "description": "Frames per second. Default 60."
    },
    "grid": {
      "$ref": "#/$defs/Grid"
    },
    "meta": {
      "$ref": "#/$defs/SceneMeta"
    },
    "sprites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Sprite"
      },
      "description": "Ordered list of sprites."
    }
  },
  "$defs": {
    "Grid": {
      "type": "object",
      "description": "Canvas logical size in cells.",
      "required": ["cols", "rows"],
      "additionalProperties": false,
      "properties": {
        "cols": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of columns (positive integer)."
        },
        "rows": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of rows (positive integer)."
        }
      }
    },
    "SceneMeta": {
      "type": "object",
      "description": "Optional metadata. Never affects rendering.",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp."
        },
        "modified": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "Sprite": {
      "type": "object",
      "description": "A single animatable element.",
      "required": ["id", "text", "keyframes"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "Unique within scene."
        },
        "text": {
          "type": "string",
          "description": "Default text if no keyframe overrides."
        },
        "hidden": {
          "type": "boolean",
          "default": false,
          "description": "Excluded from rendering if true."
        },
        "keyframes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Keyframe"
          },
          "description": "Sorted by t ascending."
        }
      }
    },
    "Keyframe": {
      "type": "object",
      "description": "A snapshot of a sprite's properties at a specific time.",
      "required": ["t"],
      "additionalProperties": false,
      "properties": {
        "t": {
          "type": "integer",
          "minimum": 0,
          "description": "Time in ms."
        },
        "x": {
          "type": "number",
          "description": "Grid columns, fractional allowed."
        },
        "y": {
          "type": "number",
          "description": "Grid rows, fractional allowed."
        },
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Opacity, 0..1."
        },
        "fontSize": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Font size in px, must be positive."
        },
        "rotation": {
          "type": "number",
          "description": "Rotation in degrees."
        },
        "color": {
          "type": "string",
          "description": "Named color token or CSS color string."
        },
        "text": {
          "type": "string",
          "description": "Overrides sprite.text at/after this keyframe."
        },
        "easing": {
          "$ref": "#/$defs/Easing"
        }
      }
    },
    "Easing": {
      "description": "Easing function for the segment ending at this keyframe.",
      "oneOf": [
        {
          "type": "string",
          "enum": ["linear", "in", "out", "inout"]
        },
        {
          "type": "object",
          "required": ["cubic"],
          "additionalProperties": false,
          "properties": {
            "cubic": {
              "type": "array",
              "items": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "minItems": 4,
              "maxItems": 4,
              "description": "Cubic bezier control points [x1, y1, x2, y2]."
            }
          }
        }
      ]
    }
  }
}
